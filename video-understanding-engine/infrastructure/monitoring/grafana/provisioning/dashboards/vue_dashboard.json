{
  "id": null,
  "uid": "vue-main",
  "title": "Video Understanding Engine",
  "tags": ["fastapi", "ai"],
  "timezone": "browser",
  "refresh": "10s",
  "schemaVersion": 38,
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"fastapi_backend\"}[1m])) by (handler)",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        }
      }
    },
    {
      "id": 2,
      "title": "HTTP Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"fastapi_backend\", status=~\"5..\"}[1m])) by (handler)",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        }
      }
    },
    {
      "id": 3,
      "title": "Request Latency P50 / P95 / P99",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 16, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"fastapi_backend\"}[1m])) by (le, handler))",
          "legendFormat": "p50 {{handler}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"fastapi_backend\"}[1m])) by (le, handler))",
          "legendFormat": "p95 {{handler}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"fastapi_backend\"}[1m])) by (le, handler))",
          "legendFormat": "p99 {{handler}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        }
      }
    },
    {
      "id": 4,
      "title": "Total Requests (1h)",
      "type": "stat",
      "gridPos": { "x": 16, "y": 8, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(increase(http_requests_total{job=\"fastapi_backend\"}[1h]))",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" }, "unit": "short" } }
    },
    {
      "id": 5,
      "title": "Error Rate %",
      "type": "stat",
      "gridPos": { "x": 20, "y": 8, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "100 * sum(rate(http_requests_total{job=\"fastapi_backend\", status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"fastapi_backend\"}[5m]))",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1}, {"color": "red", "value": 5}] },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 6,
      "title": "Active Requests",
      "type": "stat",
      "gridPos": { "x": 16, "y": 12, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(http_requests_in_progress{job=\"fastapi_backend\"})",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "purple" }, "unit": "short" } }
    },
    {
      "id": 7,
      "title": "P95 Latency (5m avg)",
      "type": "stat",
      "gridPos": { "x": 20, "y": 12, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"fastapi_backend\"}[5m])) by (le))",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 0.5}, {"color": "red", "value": 1}] },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 8,
      "title": "AI Token Usage Rate (tokens/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(ai_token_usage_total[5m])) by (model, token_type)",
          "legendFormat": "{{model}} / {{token_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 9,
      "title": "AI API Cost Accumulation (USD)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(ai_api_cost_total) by (model, operation)",
          "legendFormat": "{{model}} / {{operation}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 10,
      "title": "AI Request Latency P95 by Model",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(ai_request_latency_seconds_bucket[5m])) by (le, model, operation))",
          "legendFormat": "{{model}} / {{operation}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        }
      }
    },
    {
      "id": 11,
      "title": "Total AI Tokens (all time)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 24, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(ai_token_usage_total)",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "semi-dark-orange" }, "unit": "short" } }
    },
    {
      "id": 12,
      "title": "Total AI Cost (all time)",
      "type": "stat",
      "gridPos": { "x": 18, "y": 24, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(ai_api_cost_total)",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "semi-dark-green" }, "unit": "currencyUSD" } }
    },
    {
      "id": 13,
      "title": "Requests by Status Code",
      "type": "piechart",
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(increase(http_requests_total{job=\"fastapi_backend\"}[1h])) by (status)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "options": {
        "pieType": "donut",
        "legend": { "displayMode": "table", "placement": "right" }
      }
    },
    {
      "id": 14,
      "title": "Top Endpoints by Request Volume",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "topk(10, sum(increase(http_requests_total{job=\"fastapi_backend\"}[1h])) by (handler))",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-BlYlRd" },
          "unit": "short"
        }
      }
    }
  ]
}
